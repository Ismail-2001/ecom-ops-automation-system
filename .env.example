# ── OpsIQ Environment Configuration ──────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# App Settings
ENV=development
DEBUG=false
PROJECT_NAME=ecommerce-ops-agent

# Authentication (required in production)
API_KEY=

# CORS (comma-separated origins, no trailing slashes)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# LLM Keys (set at least one)
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Shopify (optional)
SHOPIFY_API_KEY=
SHOPIFY_PASSWORD=
SHOPIFY_STORE_URL=
SHOPIFY_API_VERSION=2024-01
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# Database (PostgreSQL required in production)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce_ops
REDIS_URL=redis://localhost:6379/0

# Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Safety Thresholds
GLOBAL_PO_LIMIT=1000.0
GLOBAL_PRICE_CHANGE_LIMIT_PERCENT=20.0
SHADOW_MODE=true
AUTO_APPROVE_THRESHOLD_DECISIONS=50
AUTO_APPROVE_CONFIDENCE_SCORE=0.95

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Notifications (optional)
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
RESEND_API_KEY=
NOTIFY_EMAIL=
