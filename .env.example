# ── Core Keys ─────────────────────────────────────────────
# Use either GOOGLE_API_KEY (Gemini) or DEEPSEEK_API_KEY (DeepSeek)
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── Auth ──────────────────────────────────────────────────
API_KEY=your-api-key-here

# ── Shopify Connector ────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_PASSWORD=
SHOPIFY_STORE_URL=
SHOPIFY_API_VERSION=2024-01

# ── Notifications ─────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#ops-alerts
RESEND_API_KEY=
NOTIFY_EMAIL=ops@example.com

# ── Infrastructure ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce_ops
REDIS_URL=redis://localhost:6379/0

# ── Safety ────────────────────────────────────────────────
GLOBAL_PO_LIMIT=1000.0
GLOBAL_PRICE_CHANGE_LIMIT_PERCENT=20.0
SHADOW_MODE=True
AUTO_APPROVE_THRESHOLD_DECISIONS=50
AUTO_APPROVE_CONFIDENCE_SCORE=0.95

# ── Environment ───────────────────────────────────────────
# Options: development, testing, production
ENV=development
DEBUG=False
