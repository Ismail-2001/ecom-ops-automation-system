# ── Docker Compose Environment Defaults ────────────────────
# This file is auto-loaded by docker-compose.yml
# Override any value in your local .env file or shell environment

# ── App ────────────────────────────────────────────────────
ENV=development
DEBUG=false
SHADOW_MODE=true

# ── LLM Keys (set your actual key in .env or shell) ───────
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── Auth ───────────────────────────────────────────────────
API_KEY=dev-api-key-change-in-production

# ── Database (Docker internal networking) ──────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce_ops
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ecommerce_ops

# ── Redis (Docker internal networking) ─────────────────────
REDIS_URL=redis://redis:6379/0

# ── Shopify (optional) ────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_PASSWORD=
SHOPIFY_STORE_URL=
SHOPIFY_API_VERSION=2024-01

# ── Notifications (optional) ──────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#ops-alerts
RESEND_API_KEY=
NOTIFY_EMAIL=

# ── Safety ────────────────────────────────────────────────
GLOBAL_PO_LIMIT=1000.0
GLOBAL_PRICE_CHANGE_LIMIT_PERCENT=20.0
AUTO_APPROVE_THRESHOLD_DECISIONS=50
AUTO_APPROVE_CONFIDENCE_SCORE=0.95
RATE_LIMIT_PER_MINUTE=60

# ── Monitoring ────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
