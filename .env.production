# ── OpsIQ Production Environment ────────────────────────────
# Copy to .env.production and fill in real values
# NEVER commit this file with real credentials

# ── Database ────────────────────────────────────────────────
POSTGRES_USER=opsiq_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS
POSTGRES_DB=ecommerce_ops

# ── Redis ───────────────────────────────────────────────────
# No password needed for internal Docker network

# ── API Security ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=CHANGE_ME_GENERATE_NEW_KEY

# ── Google Gemini (LLM) ────────────────────────────────────
GOOGLE_API_KEY=CHANGE_ME_GOOGLE_GEMINI_KEY

# ── Shopify Integration ────────────────────────────────────
SHOPIFY_API_KEY=CHANGE_ME_SHOPIFY_API_KEY
SHOPIFY_API_SECRET=CHANGE_ME_SHOPIFY_API_SECRET
SHOPIFY_ACCESS_TOKEN=CHANGE_ME_SHOPIFY_ACCESS_TOKEN
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# ── Resend (Email) ─────────────────────────────────────────
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY

# ── Observability ───────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
OTEL_ENABLED=false
OTEL_SERVICE_NAME=opsiq-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317

# ── Networking ──────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Django/Flask Secret ────────────────────────────────────
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHARS
