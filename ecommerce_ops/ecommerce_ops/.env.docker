# ── OpsIQ Docker Environment ────────────────────────────────
# Auto-loaded by docker-compose.yml via env_file
# Production secrets should come from a secrets manager (Vault, AWS SM)
# This file is safe to commit — contains only defaults/placeholders

# ── App ────────────────────────────────────────────────────
ENV=development
DEBUG=false
PROJECT_NAME=opsiq
SHADOW_MODE=true
LOG_LEVEL=INFO

# ── Authentication ──────────────────────────────────────────
# CHANGE THIS in production — use a strong random secret
# Generate: openssl rand -hex 32
API_KEY=change-me-in-production-use-random-secret

# ── LLM Keys ────────────────────────────────────────────────
# Set at least one provider key. Never commit real keys.
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=gemini-2.0-flash

# ── Database (Docker internal networking) ──────────────────
# Production: use strong passwords, separate credentials per service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=ecommerce_ops
DATABASE_URL=postgresql+asyncpg://postgres:change-me-in-production@postgres:5432/ecommerce_ops

# ── Redis (Docker internal networking) ─────────────────────
REDIS_URL=redis://redis:6379/0

# ── Connection Pool ─────────────────────────────────────────
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Shopify (optional) ────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_PASSWORD=
SHOPIFY_STORE_URL=
SHOPIFY_API_VERSION=2024-01
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_APP_URL=http://localhost:8000
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# ── Langfuse (optional — trace observability) ──────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=

# ── Notifications (optional) ──────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#ops-alerts
RESEND_API_KEY=
NOTIFY_EMAIL=

# ── Safety Thresholds ──────────────────────────────────────
GLOBAL_PO_LIMIT=1000.0
GLOBAL_PRICE_CHANGE_LIMIT_PERCENT=20.0
AUTO_APPROVE_THRESHOLD_DECISIONS=50
AUTO_APPROVE_CONFIDENCE_SCORE=0.95
RATE_LIMIT_PER_MINUTE=60

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3200"]

# ── Monitoring ────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ── Sentry (optional) ─────────────────────────────────────
SENTRY_DSN=
