# ── OpsIQ Environment Configuration ──────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── App ────────────────────────────────────────────────────
ENV=development
DEBUG=false
PROJECT_NAME=opsiq
LOG_LEVEL=INFO

# ── Authentication (required in production) ────────────────
# Generate a strong key: openssl rand -hex 32
API_KEY=

# ── Server ──────────────────────────────────────────────────
UVICORN_WORKERS=2
HTTP_PORT=8000

# ── CORS (comma-separated origins) ────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3200"]

# ── LLM Keys (set at least one) ──────────────────────────
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=gemini-2.0-flash

# ── Langfuse (optional — trace observability) ──────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=

# ── Shopify (optional) ────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_PASSWORD=
SHOPIFY_STORE_URL=
SHOPIFY_API_VERSION=2024-01
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_APP_URL=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=

# ── Database (PostgreSQL required in production) ──────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce_ops
REDIS_URL=redis://localhost:6379/0

# ── Connection Pool ────────────────────────────────────────
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ── Safety Thresholds ──────────────────────────────────────
GLOBAL_PO_LIMIT=1000.0
GLOBAL_PRICE_CHANGE_LIMIT_PERCENT=20.0
SHADOW_MODE=true
AUTO_APPROVE_THRESHOLD_DECISIONS=50
AUTO_APPROVE_CONFIDENCE_SCORE=0.95
RATE_LIMIT_PER_MINUTE=60

# ── Notifications (optional) ──────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#ops-alerts
RESEND_API_KEY=
NOTIFY_EMAIL=

# ── Error Tracking (optional) ─────────────────────────────
SENTRY_DSN=

# ── Monitoring ────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
